    "ed9b6907ea7ef4423774ccebf13a4a919a3b25eb520f4e2a5e745c37237d0f71": {
        "text": "Yes Boss?",
        "voice": "nPczCjzI2devNBz1zQrb",
        "model": "eleven_turbo_v2_5",
        "emotion": "neutral",
        "created": "2026-07-15 13:07:59.202416",
        "last_used": "2026-07-15 13:07:59.202416",
