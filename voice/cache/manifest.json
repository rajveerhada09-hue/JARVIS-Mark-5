    "7eb37ba7cf7269959f39cc399280c963345c17d647383743ecf9713929bd748b": {
        "text": "Brain is currently unavailable, Boss.",
        "voice": "nPczCjzI2devNBz1zQrb",
        "model": "eleven_turbo_v2_5",
        "emotion": "neutral",
        "created": "2026-07-15 13:07:32.107492",
