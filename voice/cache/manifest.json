    "13ae394e4b38feda695433b4c701c61f4a45b65f93c8c7966044483075f053f3": {
        "text": "Ho jayega Rajveer, Sir, abhi shaam ke 5 bajkar 4 minute ho rahe hain.",
        "voice": "nPczCjzI2devNBz1zQrb",
        "model": "eleven_turbo_v2_5",
        "emotion": "friendly",
        "created": "2026-07-17 20:34:08.528300",
        "last_used": "2026-07-17 20:34:08.528300",
