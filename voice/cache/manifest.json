    "0f96f3c9eb5f42d4b50dc56bb852182e6224f0605fa38cb5c7ea59aa4ac0ad93": {
        "text": "Main ready hoon.",
        "voice": "nPczCjzI2devNBz1zQrb",
        "model": "eleven_turbo_v2_5",
        "emotion": "neutral",
        "created": "2026-07-17 20:33:33.772727",
